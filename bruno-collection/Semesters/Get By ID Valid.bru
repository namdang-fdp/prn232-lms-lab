meta {
  name: Get By ID Valid
  type: http
  seq: 3
}

get {
  url: http://localhost:8080/api/semesters/{{semesterId}}
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("returns ApiResponse success with semester", function() {
    expect(res.status).to.equal(200);
    expect(res.body).to.have.property("success", true);
    expect(res.body.data.semesterId).to.equal(Number(bru.getVar("semesterId")));
  });
}
