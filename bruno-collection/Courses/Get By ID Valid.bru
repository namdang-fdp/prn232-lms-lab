meta {
  name: Get By ID Valid
  type: http
  seq: 3
}

get {
  url: http://localhost:8080/api/courses/{{courseId}}
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("returns ApiResponse success with course", function() {
    expect(res.status).to.equal(200);
    expect(res.body).to.have.property("success", true);
    expect(res.body.data.courseId).to.equal(Number(bru.getVar("courseId")));
  });
}
