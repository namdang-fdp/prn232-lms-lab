meta {
  name: Get Enrollments by Course
  type: http
  seq: 9
}

get {
  url: http://localhost:8080/api/courses/1/enrollments?expand=student
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("returns expanded enrollments for course", function() {
    expect(res.status).to.equal(200);
    expect(res.body.data.items).to.be.an("array").that.is.not.empty;
    expect(res.body.data.items[0].student).to.not.equal(null);
  });
}
