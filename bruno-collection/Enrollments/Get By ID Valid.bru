meta {
  name: Get By ID Valid
  type: http
  seq: 3
}

get {
  url: http://localhost:8080/api/enrollments/{{enrollmentId}}
  body: none
  auth: none
}

headers {
  Accept: application/json
}

vars:pre-request {
  enrollmentId: 1
}

tests {
  test("returns ApiResponse success with enrollment", function() {
    expect(res.status).to.equal(200);
    expect(res.body).to.have.property("success", true);
    expect(res.body.data.enrollmentId).to.equal(Number(bru.getVar("enrollmentId")));
  });
}
