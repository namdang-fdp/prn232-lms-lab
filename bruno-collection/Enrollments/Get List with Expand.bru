meta {
  name: Get List with Expand
  type: http
  seq: 8
}

get {
  url: http://localhost:8080/api/enrollments?expand=student,course&page=1&size=5
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("returns expanded enrollment relationships", function() {
    expect(res.status).to.equal(200);
    expect(res.body).to.have.property("success", true);
    expect(res.body.data.content).to.be.an("array").that.is.not.empty;
    expect(res.body.data.content[0].student).to.not.equal(null);
    expect(res.body.data.content[0].course).to.not.equal(null);
  });
}
