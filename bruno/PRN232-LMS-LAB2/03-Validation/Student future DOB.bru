meta {
  name: Student future DOB
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/students
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{adminAccessToken}}
  X-Request-Id: bruno-validation-smoke
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "fullName": "Test Student",
    "email": "test.student@example.com",
    "dateOfBirth": "2999-01-01"
  }
}

tests {
  test("future date of birth returns validation failure", function() {
    expect(res.status).to.equal(400);
    expect(res.body).to.have.property("success", false);
    expect(JSON.stringify(res.body).toLowerCase()).to.include("future");
  });
}
