meta {
  name: Student invalid FPTU email
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/students
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{adminAccessToken}}
  X-Request-Id: bruno-validation-smoke
  Accept: application/json
  Content-Type: application/json
}

body:json {
  {
    "fullName": "Test Student",
    "email": "abc@fpt.edu.vn",
    "dateOfBirth": "2000-01-01"
  }
}

tests {
  test("invalid FPTU student email returns FluentValidation failure", function() {
    expect(res.status).to.equal(400);
    expect(res.body).to.have.property("success", false);
    expect(JSON.stringify(res.body).toLowerCase()).to.include("fptu");
  });
}
