meta {
  name: v1 Courses list
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/api/v1/courses?page=1&size=3&expand=semester,subject
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("returns courses page", function() {
    expect(res.status).to.equal(200);
    expect(res.body).to.have.property("success", true);
    expect(res.body.data).to.have.property("pagination");
    expect(res.body.data.content).to.be.an("array");
  });
}
