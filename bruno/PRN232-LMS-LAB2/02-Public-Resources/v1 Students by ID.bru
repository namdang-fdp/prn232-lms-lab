meta {
  name: v1 Students by ID
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/v1/students/1
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("returns student by id", function() {
    expect(res.status).to.equal(200);
    expect(res.body).to.have.property("success", true);
    expect(res.body.data).to.have.property("studentId", 1);
  });
}
