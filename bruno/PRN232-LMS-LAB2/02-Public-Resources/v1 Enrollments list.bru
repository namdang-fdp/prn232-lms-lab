meta {
  name: v1 Enrollments list
  type: http
  seq: 6
}

get {
  url: {{baseUrl}}/api/v1/enrollments?page=1&size=3&expand=student,course
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("returns enrollments page", function() {
    expect(res.status).to.equal(200);
    expect(res.body).to.have.property("success", true);
    expect(res.body.data).to.have.property("pagination");
    expect(res.body.data.content).to.be.an("array");
  });
}
