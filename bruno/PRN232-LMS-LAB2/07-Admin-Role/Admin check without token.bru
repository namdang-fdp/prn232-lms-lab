meta {
  name: Admin check without token
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/auth/admin-check
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("admin endpoint without token returns 401", function() {
    expect(res.status).to.equal(401);
    expect(res.body).to.have.property("success", false);
  });
}
