meta {
  name: Admin check with user token
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/v1/auth/admin-check
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{userAccessToken}}
  Accept: application/json
}

tests {
  test("user token returns 403 for admin endpoint", function() {
    expect(res.status).to.equal(403);
    expect(res.body).to.have.property("success", false);
  });
}
