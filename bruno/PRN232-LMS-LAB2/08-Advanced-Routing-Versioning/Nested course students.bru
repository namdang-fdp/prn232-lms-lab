meta {
  name: Nested course students
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/courses/1/students?page=1&size=5
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("nested course students route returns page", function() {
    expect(res.status).to.equal(200);
    expect(res.body).to.have.property("success", true);
    expect(res.body.data).to.have.property("pagination");
    expect(res.body.data.content).to.be.an("array");
  });
}
